# ProCabinet.App — environment configuration template
#
# Copy this file to .env.local (gitignored) and fill in the values.
# Vite auto-loads .env.local for `npm run dev` and `npm run build`.
# In production, Cloudflare Pages injects these via the dashboard's
# Environment variables panel.
#
# The publishable (anon) key is safe for client-side exposure — Supabase
# RLS enforces row-level access. Do NOT use the service-role key here.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Stripe publishable key — safe for client-side exposure. Use the test-mode
# key (pk_test_...) for local dev and the live-mode key (pk_live_...) only
# for production. The secret key (sk_test_... / sk_live_...) NEVER goes here
# — it lives in Supabase Edge Function secrets only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Optional — local-dev test credentials. When set in .env.local (gitignored),
# the dev bundle exposes window._signInForTesting() for assistant-driven
# verification. Production builds skip this via the DEV-mode gate, but never
# commit real values here.
# VITE_TEST_EMAIL=
# VITE_TEST_PASSWORD=
