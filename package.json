{
  "name": "procabinet-app",
  "version": "0.12.0",
  "private": true,
  "scripts": {
    "predev": "pkill -f 'node_modules/.bin/vite' || true",
    "dev": "vite",
    "dev:test": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:costing": "node --test supabase/functions/_shared/costing.test.mjs",
    "build:visual-guide": "node scripts/build-visual-guide.js",
    "gen:narration": "node remotion/_src/gen-narration.mjs",
    "studio:video": "remotion studio remotion/index.ts --port 3033",
    "render:video": "remotion render remotion/index.ts CabinetWorkflow marketing/videos/workflow.mp4",
    "render:scenes": "node remotion/_src/render-scenes.mjs",
    "render:reel": "remotion render remotion/index.ts CabinetBuilderReel marketing/videos/cabinet-builder-reel.mp4",
    "render:reel-h": "node scripts/render-reel-h.mjs",
    "studio:ig": "remotion studio remotion-ig/instagram-entry.ts --no-open --port 3032",
    "render:ig": "node scripts/render-ig.mjs",
    "pdf:ig": "python3 scripts/build-ig-pdfs.py",
    "studio:ig-reel": "remotion studio remotion-ig/reel-entry.ts --public-dir=remotion-loom/public --no-open --port 3031",
    "studio:demo": "remotion studio demo-video/index.ts --public-dir=demo-video/public --no-open --port 3034",
    "render:ig-reel": "node scripts/render-reel.mjs",
    "render:loom-email": "remotion render remotion-loom/index.ts loom-email marketing/videos/loom-quote-email.mp4 --public-dir=remotion-loom/public",
    "render:loom-reel": "remotion render remotion-loom/index.ts loom-reel marketing/videos/loom-quote-reel.mp4 --public-dir=remotion-loom/public",
    "render:loom-portrait": "remotion render remotion-loom/index.ts loom-portrait marketing/videos/loom-quote-portrait.mp4 --public-dir=remotion-loom/public",
    "render:loom": "npm run render:loom-email && npm run render:loom-reel && npm run render:loom-portrait",
    "serve:videos": "node scripts/serve-videos.mjs",
    "wiki:record": "node scripts/record-wiki-clips.mjs",
    "wiki:encode": "node scripts/postprocess-wiki-clips.mjs",
    "wiki:publish": "node scripts/publish-wiki-clips.mjs",
    "wiki:clips": "npm run wiki:record && npm run wiki:encode && npm run wiki:publish",
    "indexnow": "node scripts/indexnow.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:smoke": "playwright test smoke.public.spec.js"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@playwright/test": "^1.61.0",
    "@remotion/bundler": "^4.0.464",
    "@remotion/cli": "^4.0.464",
    "@remotion/google-fonts": "^4.0.464",
    "@remotion/renderer": "^4.0.464",
    "@remotion/zod-types": "^4.0.464",
    "@sentry/vite-plugin": "^5.3.0",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "marked": "^18.0.5",
    "prettier": "^3.8.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remotion": "^4.0.464",
    "typescript": "^6.0.3",
    "vite": "^5.4.10",
    "wrangler": "^4.87.0",
    "zod": "^4.3.6"
  },
  "dependencies": {
    "@sentry/browser": "^10.53.1",
    "@supabase/supabase-js": "^2.105.1",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "posthog-js": "^1.373.4"
  },
  "overrides": {
    "dotenv": "^16.6.1"
  }
}
