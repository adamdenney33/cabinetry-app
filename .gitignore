# macOS metadata
.DS_Store

# Editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Node — node_modules is a symlink to node_modules.nosync (the .nosync suffix
# excludes it from iCloud Drive sync, which was evicting files and wedging
# reads — see SPEC.md § 13, 2026-07-11)
node_modules
node_modules/
node_modules.nosync/
node_modules.old/

# Vite build output
dist/

# Vite dev cache
.vite/
vite.config.mjs.timestamp-*.mjs

# Runtime / tool state
.playwright-mcp/
ig-dashboard/

# Playwright smoke-test artifacts (regenerated on each run)
test-results/
playwright-report/
blob-report/
playwright/.cache/

# Local env (publishable Supabase keys live here in dev)
.env
.env.local
.env.*.local

# Generated output from scripts/ (compare and copy across manually)
scripts/output/

# Sample PDFs rendered by scripts/render-pdf-samples.mjs (regenerate on demand)
pdf-samples/

# Claude Code per-user config (not shared)
.claude/settings.local.json

# Large binary / generated output — store externally
marketing/raw-footage/
marketing/videos/
marketing/audio/
out/

# Supabase local temp
supabase/.temp/

# Local helper app (machine-specific Remotion Studio launcher; not part of the build)
/Edit a Reel.app/

# Collected reels for manual upload (copies of gitignored renders)
/Reels to upload/

# Loom source copied into the Remotion public dir (large, regenerate via cp)
remotion-loom/public/*.mp4
Looms/

# Wiki workflow-clip recordings (webm/mp4/posters — published to the Supabase
# wiki-clips bucket by scripts/publish-wiki-clips.mjs; only wiki/clips.json is
# committed)
wiki/recordings/out/
