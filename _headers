# Cloudflare Pages cache rules. Copied into dist/ at build time by
# copyHeadersPlugin in vite.config.mjs (publicDir is false, so it is not picked
# up automatically). See versionClassicScriptsPlugin for the ?v= stamping that
# makes the /src rule below safe.

# Vite-hashed bundles: the filename changes whenever the content does, so a
# given URL is safe to cache forever.
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Classic /src scripts: stable filenames, but each <script> URL carries a
# ?v=<contenthash> stamp added at build time, so the URL changes when the file
# changes. Safe to cache forever; the stamp busts it on the next deploy.
/src/*
  Cache-Control: public, max-age=31536000, immutable

# Landing page's unhashed root assets — same build-time ?v= stamping as /src
# (see versionClassicScriptsPlugin), so equally safe to cache forever.
/landing.js
  Cache-Control: public, max-age=31536000, immutable
/landing.css
  Cache-Control: public, max-age=31536000, immutable

# Blog stylesheet: stable filename with a build-time ?v=<contenthash> stamp
# (added by blogPlugin), same scheme as /landing.css above.
/blog.css
  Cache-Control: public, max-age=31536000, immutable

# Wiki stylesheet: same ?v=<contenthash> scheme (stamped by build-wiki.mjs).
/wiki.css
  Cache-Control: public, max-age=31536000, immutable

# HTML must always revalidate. This is the lynchpin: the browser re-reads the
# document on every load, so it always sees the latest ?v= script URLs. Without
# this, an aggressively cached HTML would keep pointing at old script URLs.
/
  Cache-Control: public, max-age=0, must-revalidate
/os
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex
/os/
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex
# Anything under /os (auth-gated app) stays out of search indexes —
# belt-and-braces with the noindex meta in the app shell.
/os/*
  X-Robots-Tag: noindex
# Private customer quote documents: never index. Also adds the previously
# missing must-revalidate rule (quote pages could go stale for 4h without it).
/q
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex
/q.html
  Cache-Control: public, max-age=0, must-revalidate
  X-Robots-Tag: noindex
/landing.html
  Cache-Control: public, max-age=0, must-revalidate
/privacy
  Cache-Control: public, max-age=0, must-revalidate
/privacy.html
  Cache-Control: public, max-age=0, must-revalidate
/terms
  Cache-Control: public, max-age=0, must-revalidate
/terms.html
  Cache-Control: public, max-age=0, must-revalidate
# Previously missing revalidate rules (parity with /privacy and /terms).
/payment-fees
  Cache-Control: public, max-age=0, must-revalidate
/payment-fees.html
  Cache-Control: public, max-age=0, must-revalidate

# Blog pages revalidate like all other HTML.
/blog
  Cache-Control: public, max-age=0, must-revalidate
/blog/*
  Cache-Control: public, max-age=0, must-revalidate

# Wiki guide pages revalidate like all other HTML.
/wiki
  Cache-Control: public, max-age=0, must-revalidate
/wiki/*
  Cache-Control: public, max-age=0, must-revalidate

# SEO plumbing: short cache so robots/sitemap/llms changes propagate within an
# hour of a deploy; 404 page revalidates like HTML.
/robots.txt
  Cache-Control: public, max-age=3600
/sitemap.xml
  Cache-Control: public, max-age=3600
/llms.txt
  Cache-Control: public, max-age=3600
/404.html
  Cache-Control: public, max-age=0, must-revalidate
