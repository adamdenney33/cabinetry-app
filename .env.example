# ProCabinet.App — environment configuration template
#
# Copy this file to .env.local (gitignored) and fill in the values.
# Vite auto-loads .env.local for `npm run dev` and `npm run build`.
# In production, Cloudflare Pages injects these via the dashboard's
# Environment variables panel.
#
# The publishable (anon) key is safe for client-side exposure — Supabase
# RLS enforces row-level access. Do NOT use the service-role key here.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx
