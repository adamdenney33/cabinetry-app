# ProCabinet.App — environment configuration template
#
# Copy this file to .env.local (gitignored) and fill in the values.
# Vite auto-loads .env.local for `npm run dev` and `npm run build`.
# In production, Cloudflare Pages injects these via the dashboard's
# Environment variables panel.
#
# The publishable (anon) key is safe for client-side exposure — Supabase
# RLS enforces row-level access. Do NOT use the service-role key here.

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# Stripe publishable key — safe for client-side exposure. Use the test-mode
# key (pk_test_...) for local dev and the live-mode key (pk_live_...) only
# for production. The secret key (sk_test_... / sk_live_...) NEVER goes here
# — it lives in Supabase Edge Function secrets only.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# Optional — local-dev test credentials. When set in .env.local (gitignored),
# the dev bundle exposes window._signInForTesting() for assistant-driven
# verification. Production builds skip this via the DEV-mode gate, but never
# commit real values here.
# VITE_TEST_EMAIL=
# VITE_TEST_PASSWORD=

# Sentry error tracking. VITE_SENTRY_DSN identifies the project for error
# ingest — safe for client-side exposure (it can't read data). Leave blank to
# keep Sentry disabled (the SDK no-ops); set it to test error capture locally.
# In CI it's set in .github/workflows/deploy.yml.
VITE_SENTRY_DSN=

# Build-only — used by @sentry/vite-plugin during `npm run build` to upload
# source maps and create releases. NOT VITE_-prefixed: these must never reach
# the client bundle. In CI, SENTRY_AUTH_TOKEN is a GitHub Actions secret and
# the others are set in deploy.yml. Set locally only to test source-map upload.
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# PostHog product analytics — OPTIONAL. Leave BLANK in .env.local for local dev
# so dev traffic does not pollute production analytics. Powers BOTH the /os app
# (src/main.js, via import.meta.env) and the marketing landing page (landing.html
# snippet, injected at build time by copyLandingPlugin in vite.config.mjs). Same
# project + same origin, so anonymous landing activity stitches to the user's
# profile after signup. The project API key is safe for client-side exposure.
# Set both in Cloudflare Pages env vars for prod.
VITE_POSTHOG_KEY=
# PostHog API host. EU cloud: https://eu.i.posthog.com  US cloud: https://us.i.posthog.com
VITE_POSTHOG_HOST=https://eu.i.posthog.com

# ── Paid-ads tracking & conversion attribution (all OPTIONAL) ──
# Each pixel is independently env-gated in src/main.js. Leave blank in
# .env.local; set in Cloudflare Pages env vars once the ad accounts exist.
# src/main.js loads each script only when its ID is present, so unset
# variables produce zero network calls.

# Google Analytics 4 measurement ID. Format: G-XXXXXXXXXX.
# Create in Google Analytics → Admin → Data Streams → Web → measurement ID.
VITE_GA4_ID=

# Google Ads account ID. Format: AW-XXXXXXXXX (the 'AW-' prefix is required).
# Found in Google Ads UI: top-right account dropdown. Loading this enables
# tag firing and remarketing audiences; the conversion event still needs
# VITE_GOOGLE_ADS_CONVERSION_SEND_TO to be filled in to attribute signups.
VITE_GOOGLE_ADS_ID=

# Google Ads conversion `send_to` string. Format: AW-XXXXXXXXX/abcDEF12345.
# Created in Google Ads → Goals → Conversions → New conversion action
# (use 'Sign-up' template). Without this, GA4 still records sign_up events
# but Google Ads won't attribute paid-ad clicks to signups, so campaigns
# can't optimise.
VITE_GOOGLE_ADS_CONVERSION_SEND_TO=

# Meta Pixel ID (Facebook + Instagram ads). Format: 15-digit numeric string.
# Created in Meta Events Manager → Data Sources → New data source → Web.
# When set, src/main.js loads fbevents.js, fires PageView on every load, and
# the signup form fires the standard CompleteRegistration conversion event.
VITE_META_PIXEL_ID=
